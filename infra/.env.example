# ─────────────────────────────────────────────────────────────
# Inboxi environment — copy to repo root as .env and fill in.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production

# Database
DATABASE_URL="postgresql://inboxi:CHANGE_ME@localhost:5432/inboxi?schema=public"

# Redis (BullMQ + cache)
REDIS_URL="redis://localhost:6379"

# Web
NEXT_PUBLIC_SITE_URL="https://inboxi.online"
AUTH_SECRET="CHANGE_ME_openssl_rand_hex_32"

# Mail / server identity
MAIL_HOST="mail.inboxi.online"
SERVER_IP="67.205.130.18"

# Object storage (DigitalOcean Spaces — S3 compatible)
S3_ENDPOINT="https://nyc3.digitaloceanspaces.com"
S3_REGION="nyc3"
S3_BUCKET="inboxi-attachments"
S3_ACCESS_KEY="CHANGE_ME"
S3_SECRET_KEY="CHANGE_ME"

# Encryption key for secrets at rest (DKIM private keys, OAuth tokens, SMTP creds)
ENCRYPTION_KEY="CHANGE_ME_openssl_rand_hex_32"

# Cloudflare (DNS automation)
CLOUDFLARE_API_TOKEN="CHANGE_ME"
CLOUDFLARE_ACCOUNT_ID="CHANGE_ME"

# Outbound delivery — default SMTP relay (used until self-host port 25 is enabled)
SMTP_RELAY_HOST="CHANGE_ME"
SMTP_RELAY_PORT=587
SMTP_RELAY_USER="CHANGE_ME"
SMTP_RELAY_PASS="CHANGE_ME"

# Telegram
TELEGRAM_BOT_TOKEN="CHANGE_ME"

# Payments (crypto)
COINPAYMENTS_PUBLIC_KEY="CHANGE_ME"
COINPAYMENTS_PRIVATE_KEY="CHANGE_ME"
COINPAYMENTS_IPN_SECRET="CHANGE_ME"
BINANCE_PAY_API_KEY="CHANGE_ME"
BINANCE_PAY_API_SECRET="CHANGE_ME"

# Google OAuth (site-owner integrations)
GOOGLE_CLIENT_ID="CHANGE_ME"
GOOGLE_CLIENT_SECRET="CHANGE_ME"
