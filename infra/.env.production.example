# ─────────────────────────────────────────────────────────────
# Inboxi PRODUCTION environment — copy to /opt/inboxi/.env and fill in.
# Generate the secret values with: bash infra/gen-secrets.sh
# ─────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Core ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://inboxi:STRONG_DB_PASSWORD@localhost:5432/inboxi?schema=public"
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_SITE_URL="https://inboxi.online"

# ── Secrets (REQUIRED — generate, never reuse dev values) ────
AUTH_SECRET="GENERATE_ME"
ENCRYPTION_KEY="GENERATE_ME"
MAIL_INGEST_SECRET="GENERATE_ME"

# ── Mail / server identity ───────────────────────────────────
MAIL_HOST="mail.inboxi.online"
SERVER_IP="67.205.130.18"
# Where the inbound MTA posts parsed mail (local web app):
MAIL_INGEST_URL="http://127.0.0.1:3000/api/mail/inbound"
# The web app regenerates Haraka's accepted-domains list here when domains change:
HARAKA_HOST_LIST_PATH="/opt/inboxi/apps/mta-inbound/config/host_list"

# ── Object storage (DigitalOcean Spaces / S3) ────────────────
S3_ENDPOINT="https://nyc3.digitaloceanspaces.com"
S3_REGION="nyc3"
S3_BUCKET="inboxi-attachments"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ── Cloudflare DNS automation (Scenario A) ───────────────────
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""

# ── Outbound delivery (default = external SMTP relay) ────────
# Configure a DeliveryTransport row in the admin UI; these are fallbacks/refs.
SMTP_RELAY_HOST=""
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=""
SMTP_RELAY_PASS=""

# ── Telegram notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=""

# ── Crypto payments ──────────────────────────────────────────
COINPAYMENTS_PUBLIC_KEY=""
COINPAYMENTS_PRIVATE_KEY=""
COINPAYMENTS_IPN_SECRET=""
BINANCE_PAY_API_KEY=""
BINANCE_PAY_API_SECRET=""

# ── Google site-owner integrations (Phase 5+) ────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
