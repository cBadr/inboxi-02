{
  "name": "inboxi",
  "version": "0.0.0",
  "private": true,
  "description": "Inboxi — SaaS temporary email + domains platform",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @inboxi/db generate",
    "db:migrate": "pnpm --filter @inboxi/db migrate",
    "db:studio": "pnpm --filter @inboxi/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  }
}
